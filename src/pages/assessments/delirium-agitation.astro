import Layout from '../../layouts/Layout.astro';
---

<Layout title="Delirium & Agitation Assessment Tools" description="Assessment tools for delirium and agitation in nursing">
  <a href={`${import.meta.env.BASE_URL}/`} class="back-link">← Back to all categories</a>
  <div class="badge">Delirium &amp; Agitation</div>
  <h1>Delirium &amp; Agitation Assessment Tools</h1>
  <p>Tools for detecting delirium, measuring sedation levels, and assessing agitation in acute and critical care settings.</p>

  <div class="tool-list">
    <h2>Assessment Tools</h2>
    <ul>
      <li><strong>CAM-ICU (Confusion Assessment Method for the ICU)</strong> — Adapts the CAM algorithm for non-verbal ICU patients using validated attention tasks (ASE). Identifies delirium in mechanically ventilated patients.</li>
      <li><strong>3D-CAM (3-Minute Diagnostic Interview for CAM)</strong> — Structured interview completing CAM assessment in approximately 3 minutes; validated for medical inpatients.</li>
      <li><strong>bCAM (Brief CAM)</strong> — Condensed version of CAM for emergency department use. Can be completed in under 2 minutes.</li>
      <li><strong>DOS Scale (Delirium Observation Screening Scale)</strong> — Nurse-completed 13-item observational scale for delirium detection using routine care observations over nursing shifts.</li>
      <li><strong>Nu-DESC (Nursing Delirium Screening Scale)</strong> — Five-item bedside nursing scale evaluating disorientation, inappropriate behavior/communication, illusions/hallucinations, and psychomotor retardation.</li>
      <li><strong>DOSS (Delirium Observation Screening Scale)</strong> — 13-item observational tool completed by nurses during standard care interactions; validated in various inpatient settings.</li>
      <li><strong>ICDSC (Intensive Care Delirium Screening Checklist)</strong> — Eight-item checklist for ICU delirium detection over 24-hour periods. Score ≥4 indicates delirium.</li>
      <li><strong>RASS (Richmond Agitation-Sedation Scale)</strong> — Ten-point scale ranging from +4 (combative) to −5 (unarousable). Gold-standard sedation assessment in ICU; guides titration of sedation and analgesia.</li>
      <li><strong>SAS (Sedation-Agitation Scale)</strong> — Seven-level scale for ICU sedation: 1 (unarousable) to 7 (dangerous agitation). Predates RASS; still widely used.</li>
      <li><strong>Ramsay Scale</strong> — Six-level sedation scale; levels 1–3 for awake patients, 4–6 for sedated/asleep. One of the earliest validated sedation scales.</li>
      <li><strong>Pittsburgh Agitation Scale (PAS)</strong> — Four-domain scale assessing vocalization, motor agitation, pulling at tubes/restraints, and global agitation. Scores 0–14.</li>
      <li><strong>OAS (Overt Aggression Scale)</strong> — Measures verbal and physical aggression in psychiatric patients; guides intervention documentation.</li>
      <li><strong>BARS (Behavioral Activity Rating Scale)</strong> — Seven-level scale for agitation assessment in procedural and acute care; simple enough for rapid bedside use.</li>
      <li><strong>MAAS (Motor Activity Assessment Scale)</strong> — Seven-level scale assessing motor activity from unresponsive to dangerously agitated; validated for ICU settings.</li>
      <li><strong>CAM-S (CAM Severity Score)</strong> — Extension of the CAM that quantifies delirium severity (short form 0–7; long form 0–19) rather than simply detecting its presence.</li>
    </ul>
  </div>
</Layout>
